#!/bin/bash

# Environment variables for basyn tests
# This file should be sourced in each test script

# Get script directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Determine tmpdir (prefer ramdisk)
if [ -d "/dev/shm" ]; then
    TMPDIR="/dev/shm"
elif [ -d "/tmp" ]; then
    TMPDIR="/tmp"
else
    TMPDIR="${SCRIPT_DIR}"
fi

# Declare environment variables
export SOURCE_FILE="${TMPDIR}/basyn_source_$$"
export DEST_FILE="${TMPDIR}/basyn_dest_$$"
export TMPDIR  # Export TMPDIR for use in tests
export BASYN="${SCRIPT_DIR}/../basyn"

# Test configuration
export TEST_FILE_SIZE_MB="${TEST_FILE_SIZE_MB:-24}"  # Default test file size in MB
export TEST_HASH_FUNC="${TEST_HASH_FUNC:-SHA1}"       # Default hash function
export TEST_BUFFER_SIZE="${TEST_BUFFER_SIZE:-2048}"   # Default buffer size in KB

# Temporary files cleanup management
# 1 - delete files after tests, 0 - keep for debugging
export CLEANUP="${CLEANUP:-1}"

# Check basyn existence
if [ ! -f "$BASYN" ]; then
    echo "Error: basyn not found at $BASYN"
    exit 1
fi

# Color codes for output
export GREEN='\033[0;32m'
export RED='\033[0;31m'
export NC='\033[0m' # No Color

# Functions for colored output with symbols
print_success() {
    echo -e "${GREEN}✓ $*${NC}"
}

print_error() {
    echo -e "${RED}✗ $*${NC}"
}
