#!/bin/bash

# Meta-test: Run tests with different buffer sizes
# This test verifies that basyn works correctly with various buffer sizes

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
TESTS_DIR="$SCRIPT_DIR"  # Save before sourcing tests-env
source "${SCRIPT_DIR}/../tests-env"

# Buffer sizes to test (in KB)
# Note: default is 2048KB (2MB)
TEST_BUFFERS=(512 4096 8192 333 771)

# Counters
TOTAL=0
PASSED=0
FAILED=0

echo "========================================"
echo "  Meta-test: Different buffer sizes"
echo "========================================"
echo ""

for buffer in "${TEST_BUFFERS[@]}"; do
    echo "========================================"
    echo "  Testing with buffer: ${buffer}KB"
    echo "========================================"
    echo ""
    
    # Run SYNC tests with this buffer size (skip COPY tests as they don't use buffer for comparison)
    for test_script in "${TESTS_DIR}"/*-test-*sync* "${TESTS_DIR}"/*-test-*bitmap*; do
        [ -f "$test_script" ] || continue
        
        # Skip 9xx tests (meta-tests)
        test_name=$(basename "$test_script")
        [[ "$test_name" =~ ^9 ]] && continue
        
        TOTAL=$((TOTAL + 1))
        
        echo "----------------------------------------"
        echo "Running: $test_name (buffer=${buffer}KB)"
        echo "----------------------------------------"
        
        # Run test with overridden TEST_BUFFER_SIZE
        if TEST_BUFFER_SIZE=$buffer bash "$test_script"; then
            PASSED=$((PASSED + 1))
            echo ""
        else
            FAILED=$((FAILED + 1))
            echo "ERROR in test: $test_name with buffer=${buffer}KB"
            echo ""
        fi
    done
done

# Summary report
echo "========================================"
echo "  Meta-test Results"
echo "========================================"
echo "Buffer sizes tested: ${TEST_BUFFERS[*]} KB"
echo "Total test runs:     $TOTAL"
echo "Passed:              $PASSED"
echo "Failed:              $FAILED"
echo "========================================"

# Return error code if there were failures
if [ $FAILED -gt 0 ]; then
    exit 1
else
    exit 0
fi
