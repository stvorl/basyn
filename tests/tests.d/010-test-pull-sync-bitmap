#!/bin/bash

# Test: PULL SYNC with BITMAP (first run - create bitmap)

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

BITMAP_FILE="${TMPDIR}/basyn_bitmap_$$"

# Create 32MB source file filled with /dev/urandom
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=32 status=progress

# Create 32MB dest file filled with zeros
dd if=/dev/zero of="$DEST_FILE" bs=1M count=32 status=progress

# First run - create bitmap
"$BASYN" -l "$DEST_FILE" -r "$SOURCE_FILE" -a PULL -m SYNC --bitmap="$BITMAP_FILE" --recheck --stat --progress
echo

if cmp -s "$SOURCE_FILE" "$DEST_FILE"; then
    echo "==== PULL SYNC BITMAP (first run) working"
    RESULT=0
else
    echo "==== PULL SYNC BITMAP (first run) failed"
    RESULT=1
fi

# Check that bitmap file was created
if [ ! -f "$BITMAP_FILE" ]; then
    echo "==== PULL SYNC BITMAP failed - bitmap file not created"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE"
fi

exit $RESULT
