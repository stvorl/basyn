#!/bin/bash

# Test: PULL SYNC with BITMAP only (no destination device)

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

BITMAP_FILE="${TMPDIR}/basyn_bitmap_$$"

# Create source file filled with /dev/urandom
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=progress

# Run without destination - bitmap update only
"$BASYN" -r "$SOURCE_FILE" -a PULL -m SYNC --hash="$TEST_HASH_FUNC" --buffer="$TEST_BUFFER_SIZE" --bitmap="$BITMAP_FILE" --stat --progress
echo

# Check that bitmap file was created
if [ -f "$BITMAP_FILE" ]; then
    print_success "PULL SYNC BITMAP-ONLY working"
    RESULT=0
else
    print_error "PULL SYNC BITMAP-ONLY failed - bitmap file not created"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE"
fi

exit $RESULT
