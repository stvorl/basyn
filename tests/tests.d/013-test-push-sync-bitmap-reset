#!/bin/bash

# Test: PUSH SYNC with BITMAP RESET
# This test verifies that --reset-bitmap correctly rebuilds the bitmap
# even when destination has been modified

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

BITMAP_FILE="${TMPDIR}/basyn_bitmap_$$"

echo "==== Test PUSH SYNC with BITMAP RESET ===="
echo

# Step 1: Create source file filled with /dev/urandom
echo "Step 1: Creating source file..."
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=none

# Create dest file filled with zeros
echo "Step 2: Creating destination file..."
dd if=/dev/zero of="$DEST_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=none

# Step 3: Initial sync with bitmap
echo "Step 3: Initial sync with bitmap creation..."
"$BASYN" -l "$SOURCE_FILE" -r "$DEST_FILE" -a PUSH -m SYNC --hash="$TEST_HASH_FUNC" --buffer="$TEST_BUFFER_SIZE" --bitmap="$BITMAP_FILE" --stat --progress
echo

if ! cmp -s "$SOURCE_FILE" "$DEST_FILE"; then
    print_error "PUSH SYNC BITMAP RESET failed - initial sync did not match"
    [ "$CLEANUP" = "1" ] && rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE"
    exit 1
fi
echo "Initial sync successful - files match"
echo

# Step 4: Modify destination file (corrupt it)
echo "Step 4: Modifying destination file to simulate desync..."
# Modify 25% of file starting from 50% offset
MODIFY_SIZE=$(( TEST_FILE_SIZE_MB / 4 ))
# Ensure at least 1MB modification
[ $MODIFY_SIZE -lt 1 ] && MODIFY_SIZE=1
SEEK_POS=$(( TEST_FILE_SIZE_MB / 2 ))
dd if=/dev/urandom of="$DEST_FILE" bs=1M count=$MODIFY_SIZE seek=$SEEK_POS conv=notrunc status=none
echo "Destination modified at offset ${SEEK_POS}MB (${MODIFY_SIZE}MB changed)"
echo

# Step 5: Sync again with bitmap (should NOT fix, because bitmap is out of sync with dest)
echo "Step 5: Syncing with existing bitmap (should not detect dest changes)..."
"$BASYN" -l "$SOURCE_FILE" -r "$DEST_FILE" -a PUSH -m SYNC --hash="$TEST_HASH_FUNC" --buffer="$TEST_BUFFER_SIZE" --bitmap="$BITMAP_FILE" --stat --progress
echo

if cmp -s "$SOURCE_FILE" "$DEST_FILE"; then
    print_error "PUSH SYNC BITMAP RESET failed - files should still be different"
    [ "$CLEANUP" = "1" ] && rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE"
    exit 1
fi
echo "Files are still different (as expected) - bitmap doesn't know about dest changes"
echo

# Step 6: Sync with --reset-bitmap (should fix everything)
echo "Step 6: Syncing with --reset-bitmap (should rebuild and sync properly)..."
"$BASYN" -l "$SOURCE_FILE" -r "$DEST_FILE" -a PUSH -m SYNC --hash="$TEST_HASH_FUNC" --buffer="$TEST_BUFFER_SIZE" --bitmap="$BITMAP_FILE" --reset-bitmap --stat --progress
echo

if cmp -s "$SOURCE_FILE" "$DEST_FILE"; then
    print_success "PUSH SYNC BITMAP RESET working - files match after reset"
    RESULT=0
else
    print_error "PUSH SYNC BITMAP RESET failed - files do not match after reset"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE"
fi

exit $RESULT
