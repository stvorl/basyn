#!/bin/bash

# Test: PULL SYNC with BITMAP (reuse existing bitmap)

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

BITMAP_FILE="${TMPDIR}/basyn_bitmap_$$"

# Create source file filled with /dev/urandom
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=progress

# Create dest file filled with zeros
dd if=/dev/zero of="$DEST_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=progress

# First run - create bitmap and sync
"$BASYN" -l "$DEST_FILE" -r "$SOURCE_FILE" -a PULL -m SYNC --hash="$TEST_HASH_FUNC" --buffer="$TEST_BUFFER_SIZE" --bitmap="$BITMAP_FILE" --stat --progress
echo "First sync completed (bitmap created)"

# Save copy of original source for verification
cp "$SOURCE_FILE" "${SOURCE_FILE}.original"

# Modify part of SOURCE file (remote in PULL mode - simulate incremental change)
# Modify 25% of file starting from 50% offset
MODIFY_SIZE=$(( TEST_FILE_SIZE_MB / 4 ))
SEEK_POS=$(( TEST_FILE_SIZE_MB / 2 ))
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=$MODIFY_SIZE seek=$SEEK_POS conv=notrunc status=none

# Second run - bitmap will detect changes in source and transfer only them
"$BASYN" -l "$DEST_FILE" -r "$SOURCE_FILE" -a PULL -m SYNC --hash="$TEST_HASH_FUNC" --buffer="$TEST_BUFFER_SIZE" --bitmap="$BITMAP_FILE" --recheck --stat --progress
echo

if cmp -s "$SOURCE_FILE" "$DEST_FILE"; then
    print_success "PULL SYNC BITMAP (reuse) working"
    RESULT=0
else
    print_error "PULL SYNC BITMAP (reuse) failed"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE" "${SOURCE_FILE}.original"
fi

exit $RESULT
