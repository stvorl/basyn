#!/bin/bash

# Test: PUSH COPY

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

# Create source file filled with /dev/urandom
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=progress

# Create dest file filled with zeros
dd if=/dev/zero of="$DEST_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=progress

"$BASYN" -l "$SOURCE_FILE" -r "$DEST_FILE" -a PUSH -m COPY --recheck --stat --progress
echo

if cmp -s "$SOURCE_FILE" "$DEST_FILE"; then
    print_success "PUSH COPY working"
    RESULT=0
else
    print_error "PUSH COPY failed"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE"
fi

exit $RESULT
