#!/bin/bash

# Test: RECHECK only mode (without action)

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

# Create source file filled with /dev/urandom
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=$TEST_FILE_SIZE_MB status=progress

# Copy to dest file (should be identical)
cp "$SOURCE_FILE" "$DEST_FILE"

"$BASYN" -l "$SOURCE_FILE" -r "$DEST_FILE" --hash="$TEST_HASH_FUNC" --recheck --stat --progress
BASYN_EXIT=$?
echo

if [ $BASYN_EXIT -eq 0 ]; then
    print_success "RECHECK only working"
    RESULT=0
else
    print_error "RECHECK only failed"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE"
fi

exit $RESULT
