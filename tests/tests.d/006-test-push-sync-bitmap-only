#!/bin/bash

# Test: PUSH SYNC with BITMAP only (no destination device)

# Load environment variables
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "${SCRIPT_DIR}/../tests-env"

BITMAP_FILE="${TMPDIR}/basyn_bitmap_$$"

# Create 32MB source file filled with /dev/urandom
dd if=/dev/urandom of="$SOURCE_FILE" bs=1M count=32 status=progress

# Run without destination - bitmap update only
"$BASYN" -l "$SOURCE_FILE" -a PUSH -m SYNC --bitmap="$BITMAP_FILE" --stat --progress
echo

# Check that bitmap file was created
if [ -f "$BITMAP_FILE" ]; then
    echo "==== PUSH SYNC BITMAP-ONLY working"
    RESULT=0
else
    echo "==== PUSH SYNC BITMAP-ONLY failed - bitmap file not created"
    RESULT=1
fi

# Cleanup temporary files
if [ "$CLEANUP" = "1" ]; then
    rm -f "$SOURCE_FILE" "$DEST_FILE" "$BITMAP_FILE"
fi

exit $RESULT
